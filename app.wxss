/**app.wxss — iOS 26 Liquid Glass Design System**/

page {
  --page-bg: linear-gradient(180deg, #F8F8FA 0%, #F3F4F8 45%, #FFF4F0 100%);
  --glass-bg: rgba(255, 255, 255, 0.62);
  --glass-bg-strong: rgba(255, 255, 255, 0.78);
  --glass-bg-hover: rgba(255, 255, 255, 0.72);
  --glass-border: rgba(255, 255, 255, 0.72);
  --glass-stroke: rgba(0, 0, 0, 0.05);
  --glass-stroke-strong: rgba(0, 0, 0, 0.08);
  --glass-highlight: inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
  --primary: #FF7A6B;
  --primary-soft: rgba(255, 122, 107, 0.14);
  --primary-glow: rgba(255, 122, 107, 0.20);
  --blue-accent: #5AC8FA;
  --blue-soft: rgba(90, 200, 250, 0.14);
  --text-primary: #111111;
  --text-secondary: #6E6E73;
  --text-tertiary: #A1A1AA;
  --text-inverse: #FFFFFF;
  --shadow-glass: 0 20rpx 60rpx rgba(31, 35, 45, 0.10);
  --shadow-soft: 0 8rpx 28rpx rgba(31, 35, 45, 0.06);
  --shadow-float: 0 4rpx 16rpx rgba(31, 35, 45, 0.04);
  --shadow-inner: inset 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
  --radius-xl: 44rpx;
  --radius-lg: 32rpx;
  --radius-md: 24rpx;
  --radius-sm: 16rpx;
  --radius-pill: 999rpx;
  --transition-fast: 0.15s cubic-bezier(0.4, 0, 0.2, 1);
  --transition-base: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  --transition-spring: 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  --font-stack: -apple-system, BlinkMacSystemFont, "SF Pro Display", "PingFang SC", "Noto Sans SC", sans-serif;
}

.container {
  min-height: 100vh;
  background: var(--page-bg);
  font-family: var(--font-stack);
  color: var(--text-primary);
  -webkit-font-smoothing: antialiased;
}

/* ===== 全局动画 ===== */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(16rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes fadeScale {
  from { opacity: 0; transform: scale(0.96); }
  to { opacity: 1; transform: scale(1); }
}

@keyframes sheetSlideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

@keyframes popIn {
  from { opacity: 0; transform: scale(0.92); }
  to { opacity: 1; transform: scale(1); }
}

@keyframes floatUp {
  from { opacity: 0; transform: translateY(40rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(30rpx) scale(0.98); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}

@keyframes glowPulse {
  0%, 100% { opacity: 0.6; }
  50% { opacity: 1; }
}

@keyframes shake {
  0%, 100% { transform: translateX(0); }
  10%, 30%, 50%, 70%, 90% { transform: translateX(-6rpx); }
  20%, 40%, 60%, 80% { transform: translateX(6rpx); }
}

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

/* ===== 工具类 ===== */
.glass {
  background: var(--glass-bg);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border: 1rpx solid var(--glass-border);
  box-shadow: var(--glass-highlight), var(--shadow-glass);
}

.glass-strong {
  background: var(--glass-bg-strong);
  backdrop-filter: blur(60rpx);
  -webkit-backdrop-filter: blur(60rpx);
  border: 1rpx solid var(--glass-border);
  box-shadow: var(--glass-highlight), var(--shadow-glass);
}

.glass-subtle {
  background: var(--glass-bg);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
  border: 1rpx solid var(--glass-stroke);
  box-shadow: var(--glass-highlight), var(--shadow-soft);
}

.text-center { text-align: center; }
.sr-only { position: absolute; width: 1rpx; height: 1rpx; overflow: hidden; }
