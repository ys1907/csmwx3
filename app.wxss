/**app.wxss — Design Tokens（Apple HIG 启发，适配微信小程序）**/
/* 说明：保留历史变量名（--glass-* 等）作为别名映射到干净值，
   这样旧页面的 var(--xxx) 引用无需逐行改写即可获得新外观。 */

page {
  /* ===== 背景 / 卡片 / 填充 ===== */
  --page-bg: #F5F5F7;
  --card-bg: #FFFFFF;
  --fill-subtle: rgba(120, 120, 128, 0.08);   /* 标签、输入框等次级填充 */
  --fill-hover: rgba(120, 120, 128, 0.16);
  --separator: rgba(60, 60, 67, 0.12);

  /* ===== 语义色 ===== */
  --primary: #FF7A00;                          /* 主操作色：暖橙，食物/温暖氛围 */
  --primary-soft: rgba(255, 122, 0, 0.12);
  --primary-glow: rgba(255, 122, 0, 0.25);
  --secondary: #5AC8FA;                        /* 辅助色：清爽蓝 */
  --secondary-soft: rgba(90, 200, 250, 0.12);
  --food-accent: #FF9F0A;                      /* 食物高亮，独立于主操作色 */
  --food-soft: rgba(255, 159, 10, 0.14);
  --success: #34C759;
  --danger: #FF3B30;
  --blue-accent: #5AC8FA;
  --blue-soft: rgba(90, 200, 250, 0.12);
  --orange-accent: #FF9F0A;
  --orange-soft: rgba(255, 159, 10, 0.14);

  /* ===== 文字 ===== */
  --text-primary: #1D1D1F;
  --text-secondary: #6E6E73;
  --text-tertiary: #8E8E93;
  --text-inverse: #FFFFFF;

  /* ===== 阴影（克制、轻） ===== */
  --shadow-card: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  --shadow-soft: 0 8rpx 28rpx rgba(0, 0, 0, 0.06);
  --shadow-float: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  --shadow-sheet: 0 -8rpx 40rpx rgba(0, 0, 0, 0.12);
  --shadow-inner: inset 0 1rpx 2rpx rgba(0, 0, 0, 0.04);
  /* 阴影层级（精简为三级语义） */
  --shadow-none: 0 0 0 0 rgba(0, 0, 0, 0);

  /* ===== 圆角（差异化档位，不让所有元素同圆角） ===== */
  --radius-xl: 36rpx;   /* 主卡片 */
  --radius-lg: 28rpx;   /* 区块 / Sheet */
  --radius-md: 20rpx;   /* 按钮 / 输入 */
  --radius-sm: 14rpx;   /* 小元素 */
  --radius-pill: 999rpx;/* 标签 / 分段 */

  /* ===== 动效 ===== */
  --transition-fast: 0.15s cubic-bezier(0.4, 0, 0.2, 1);
  --transition-base: 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  --transition-spring: 0.45s cubic-bezier(0.34, 1.4, 0.64, 1);

  /* ===== 字体（系统字体栈，不嵌入 SF 字体文件） ===== */
  --font-stack: -apple-system, BlinkMacSystemFont, "PingFang SC", "Noto Sans SC", "Helvetica Neue", sans-serif;

  /* ===== 字号阶梯（type scale） ===== */
  --text-xs: 22rpx;
  --text-sm: 24rpx;
  --text-base: 28rpx;
  --text-lg: 32rpx;
  --text-xl: 36rpx;
  --text-2xl: 40rpx;
  --text-3xl: 48rpx;
  --text-4xl: 56rpx;

  /* ===== 历史「玻璃」别名 → 映射为干净值（旧引用自动生效） ===== */
  --glass-bg: #FFFFFF;
  --glass-bg-strong: #FFFFFF;
  --glass-bg-hover: #F5F5F7;
  --glass-border: rgba(60, 60, 67, 0.10);
  --glass-stroke: rgba(60, 60, 67, 0.10);
  --glass-stroke-strong: rgba(60, 60, 67, 0.16);
  --glass-highlight: 0 0 0 0 rgba(0, 0, 0, 0);
  --shadow-glass: 0 8rpx 28rpx rgba(0, 0, 0, 0.06); /* 已废弃，请使用 --shadow-card */

  /* Sheet 材质：默认纯色（低端降级），支持时叠加轻微半透明 */
  --sheet-bg: #FFFFFF;
}

/* ===== 暗黑模式：同名变量覆盖 ===== */
.dark {
  --page-bg: #000000;
  --card-bg: #1C1C1E;
  --fill-subtle: rgba(120, 120, 128, 0.24);
  --fill-hover: rgba(120, 120, 128, 0.36);
  --separator: rgba(84, 84, 88, 0.40);

  --primary: #FF9F0A;
  --primary-soft: rgba(255, 159, 10, 0.20);
  --primary-glow: rgba(255, 159, 10, 0.35);
  --secondary: #5AC8FA;
  --secondary-soft: rgba(90, 200, 250, 0.18);
  --food-accent: #FFD60A;
  --food-soft: rgba(255, 214, 10, 0.18);
  --success: #30D158;
  --danger: #FF453A;

  --text-primary: #FFFFFF;
  --text-secondary: #98989D;
  --text-tertiary: #636366;
  --text-inverse: #1C1C1E;

  --shadow-card: 0 2rpx 12rpx rgba(0, 0, 0, 0.4);
  --shadow-soft: 0 8rpx 28rpx rgba(0, 0, 0, 0.5);
  --shadow-float: 0 4rpx 16rpx rgba(0, 0, 0, 0.4);
  --shadow-sheet: 0 -8rpx 40rpx rgba(0, 0, 0, 0.6);

  --glass-bg: #1C1C1E;
  --glass-bg-strong: #2C2C2E;
  --glass-bg-hover: #2C2C2E;
  --glass-border: rgba(255, 255, 255, 0.12);
  --glass-stroke: rgba(255, 255, 255, 0.10);
  --glass-stroke-strong: rgba(255, 255, 255, 0.16);
  --shadow-glass: 0 8rpx 28rpx rgba(0, 0, 0, 0.5);
  --sheet-bg: #1C1C1E;
}

.container {
  min-height: 100vh;
  background: var(--page-bg);
  font-family: var(--font-stack);
  color: var(--text-primary);
  -webkit-font-smoothing: antialiased;
}

/* ===== 全局动画（克制、可中断；时长符合规范） ===== */
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
@keyframes fadeScale {
  from { opacity: 0; transform: scale(0.98); }
  to { opacity: 1; transform: scale(1); }
}
@keyframes sheetSlideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}
@keyframes popIn {
  from { opacity: 0; transform: scale(0.96); }
  to { opacity: 1; transform: scale(1); }
}
@keyframes floatUp {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(16rpx); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes glowPulse {
  0%, 100% { opacity: 0.6; }
  50% { opacity: 1; }
}
@keyframes shake {
  0%, 100% { transform: translateX(0); }
  10%, 30%, 50%, 70%, 90% { transform: translateX(-5rpx); }
  20%, 40%, 60%, 80% { transform: translateX(5rpx); }
}

/* ===== 全局组件类（两页共用，集中在此避免重复定义） ===== */

/* 卡片 */
.card {
  background: var(--card-bg);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}

/* 主按钮（HIG 填充蓝）—— 保留 .btn-glass 类名以兼容现有 WXML */
.btn-glass {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  min-height: 88rpx;                 /* 点击区 ≥ 88rpx */
  padding: 0 48rpx;
  border-radius: var(--radius-md);
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  background: var(--primary);
  color: var(--text-inverse);
  box-shadow: var(--shadow-float);
  transition: transform var(--transition-fast), opacity var(--transition-fast);
  line-height: 1.2;
}
.btn-glass::after { border: none; }      /* 去掉小程序 button 默认边框 */
.btn-glass:active { transform: scale(0.98); box-shadow: 0 0 24rpx var(--primary-glow); }
.btn-glass:focus { outline: 3rpx solid var(--primary); outline-offset: 2rpx; }

/* 次按钮（描边/中性填充） */
.btn-glass-secondary {
  background: var(--fill-subtle);
  color: var(--text-primary);
  box-shadow: none;
}
.btn-glass-secondary:active { background: var(--fill-hover); transform: scale(0.98); }
.btn-glass-secondary:focus { outline: 3rpx solid var(--primary); outline-offset: 2rpx; }

/* 文字按钮 */
.btn-glass-ghost {
  background: transparent;
  color: var(--primary);
  box-shadow: none;
}
.btn-glass-ghost:active { opacity: 0.6; }
.btn-glass-ghost:focus { outline: 3rpx solid var(--primary); outline-offset: 2rpx; }

/* 破坏性按钮 */
.btn-danger {
  display: inline-flex; align-items: center; justify-content: center;
  min-height: 88rpx; padding: 0 48rpx;
  border-radius: var(--radius-md);
  font-size: 30rpx; font-weight: 600; border: none;
  background: var(--danger); color: #fff;
}
.btn-danger::after { border: none; }
.btn-danger:active { opacity: 0.9; transform: scale(0.98); }
.btn-danger:focus { outline: 3rpx solid var(--danger); outline-offset: 2rpx; }

/* 胶囊标签 */
.tag {
  font-size: 22rpx;
  font-weight: 500;
  color: var(--text-secondary);
  background: var(--fill-subtle);
  padding: 6rpx 18rpx;
  border-radius: var(--radius-pill);
}

/* 细分隔线 */
.hairline { height: 1rpx; background: var(--separator); }

/* ===== 焦点环（无障碍） ===== */
.focus-ring:focus { outline: 3rpx solid var(--primary); outline-offset: 2rpx; }

/* ===== CSS 几何图标系统 ===== */
.icon-settings {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  width: 32rpx;
  height: 32rpx;
}
.icon-settings::before,
.icon-settings::after,
.icon-settings > view::before {
  content: '';
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: currentColor;
}

.icon-close {
  display: inline-block;
  width: 24rpx;
  height: 24rpx;
  position: relative;
}
.icon-close::before,
.icon-close::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 16rpx;
  height: 2rpx;
  background: currentColor;
  border-radius: 1rpx;
}
.icon-close::before { transform: translate(-50%, -50%) rotate(45deg); }
.icon-close::after  { transform: translate(-50%, -50%) rotate(-45deg); }

.icon-combo {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 28rpx;
  height: 28rpx;
  border: 2rpx solid currentColor;
  border-radius: 50%;
  position: relative;
}
.icon-combo::before,
.icon-combo::after {
  content: '';
  position: absolute;
  background: currentColor;
  border-radius: 1rpx;
}
.icon-combo::before { width: 12rpx; height: 2rpx; }
.icon-combo::after  { width: 2rpx; height: 12rpx; }

/* ===== 工具类 ===== */
.text-center { text-align: center; }
.sr-only { position: absolute; width: 1rpx; height: 1rpx; overflow: hidden; }

/* ===== 减少动态效果支持（无障碍） ===== */
@media (prefers-reduced-motion: reduce) {
  page, view, text, image, button, input, textarea, scroll-view, swiper, picker, canvas, cover-view, cover-image, navigator {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
  }
}
.tap-target { min-width: 88rpx; min-height: 88rpx; display: flex; align-items: center; justify-content: center; }
