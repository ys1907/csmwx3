/** pages/manage/manage.wxss — iOS 26 Liquid Glass **/

/* ===== 顶部导航 ===== */
.manage-header {
  position: relative;
  z-index: 10;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx 24rpx;
}
.back-btn {
  position: relative;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: var(--glass-bg-strong);


  border: 1rpx solid var(--glass-border);
  box-shadow: var(--shadow-card);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--transition-fast);
  z-index: 100;
}
.back-btn-hover {
  transform: scale(0.92);
  background: var(--glass-bg-hover);
}
.back-icon {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1;
  margin-left: -4rpx;
}
.manage-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -0.5rpx;
}

/* ===== 主内容区 ===== */
.main-content {
  position: relative;
  z-index: 10;
  padding: 0 40rpx 40rpx;
}

/* ===== 玻璃区块 ===== */
.section-glass {
  background: var(--glass-bg);


  border-radius: var(--radius-lg);
  border: 1rpx solid var(--glass-border);
  box-shadow: var(--shadow-card);
  margin-bottom: 24rpx;
  overflow: hidden;
}
.section-header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid var(--glass-stroke);
}
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}
.section-count {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* ===== 表单 ===== */
.form-glass {
  padding: 24rpx 32rpx;
}
.form-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}
.form-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
  background: rgba(0,0,0,0.03);
  padding: 20rpx 24rpx;
  border-radius: var(--radius-md);
  border: 1rpx solid var(--glass-stroke);
  transition: border-color var(--transition-fast);
}
.form-input:focus {
  border-color: var(--primary);
}
.form-picker {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
  background: rgba(0,0,0,0.03);
  padding: 20rpx 24rpx;
  border-radius: var(--radius-md);
  border: 1rpx solid var(--glass-stroke);
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.form-picker-label {
  color: var(--text-tertiary);
}
.form-picker-value {
  color: var(--text-primary);
  font-weight: 500;
}
.form-picker-chevron {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-left: 8rpx;
}

/* ===== 列表项 ===== */
.list-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid var(--glass-stroke);
}
.list-item:last-child {
  border-bottom: none;
}
.list-item-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.list-emoji {
  font-size: 36rpx;
  width: 48rpx;
  text-align: center;
}
.list-name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
}
.list-tags {
  display: flex;
  gap: 8rpx;
  margin-top: 4rpx;
}
.list-tag {
  font-size: 20rpx;
  color: var(--text-tertiary);
  background: rgba(0,0,0,0.04);
  padding: 4rpx 12rpx;
  border-radius: var(--radius-pill);
}
.list-delete {
  font-size: 24rpx;
  color: #FF3B30;
  /* 行内文字按钮：内边距撑到 ≥88rpx 触控高度，负外边距抵消行高占位 */
  padding: 28rpx 20rpx;
  margin: -20rpx -8rpx;
  transition: opacity var(--transition-fast);
}
.list-delete-hover {
  opacity: 0.6;
}

/* ===== 空状态 ===== */
.empty-state {
  text-align: center;
  padding: 60rpx 32rpx;
  position: relative;
}
/* 空状态 CSS 插图 */
.empty-state::before {
  content: '';
  display: block;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 3rpx solid var(--separator);
  margin: 0 auto 20rpx;
  background:
    radial-gradient(circle at 45% 40%, var(--primary-soft) 18%, transparent 19%),
    radial-gradient(circle at 55% 55%, var(--orange-soft) 14%, transparent 15%);
  opacity: 0.6;
}
.empty-text {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

/* ===== 搜索栏 ===== */
.search-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: var(--fill-subtle);
  border-radius: var(--radius-md);
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
}
.search-icon { font-size: 26rpx; opacity: 0.6; }
.search-input { flex: 1; font-size: 28rpx; color: var(--text-primary); }
.search-clear {
  font-size: 24rpx;
  color: var(--text-tertiary);
  min-width: 56rpx; min-height: 56rpx;
  display: flex; align-items: center; justify-content: center;
}

/* ===== 分类筛选 chips ===== */
.chip-scroll { white-space: nowrap; }
.chip-row { display: inline-flex; gap: 12rpx; padding: 4rpx 0; }
.chip {
  display: inline-block;
  padding: 12rpx 28rpx;
  border-radius: var(--radius-pill);
  background: var(--fill-subtle);
  font-size: 24rpx;
  color: var(--text-secondary);
  white-space: nowrap;
  transition: all var(--transition-fast);
}
.chip:focus { outline: 3rpx solid var(--primary); outline-offset: 2rpx; }
.chip-active {
  background: var(--primary);
  color: #fff;
  font-weight: 600;
}

/* ===== 列表项编辑态 ===== */
.list-item { transition: background var(--transition-fast); }
.list-item-hover { background: var(--fill-subtle); }
.list-item:focus { outline: 3rpx solid var(--primary); outline-offset: 2rpx; }
.list-edit { font-size: 36rpx; color: var(--text-tertiary); line-height: 1; }
.list-item-right { display: flex; align-items: center; gap: 16rpx; }
/* 分批渲染的「显示更多」展开行：克制、可点，融入列表 */
.list-more {
  padding: 24rpx 32rpx;
  text-align: center;
  border-top: 1rpx solid var(--glass-stroke);
  transition: background var(--transition-fast);
}
.list-more-hover { background: var(--fill-subtle); }
.list-more-text { font-size: 26rpx; color: var(--primary); font-weight: 600; }

/* ===== 底部 Sheet（新增/编辑菜品） ===== */
.sheet-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 9999;
  background: rgba(0, 0, 0, 0.4);
  animation: fadeIn 0.25s ease both;
}
.sheet-content {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  box-shadow: var(--shadow-sheet);
  animation: sheetSlideUp 0.3s cubic-bezier(0.32, 0.72, 0, 1) both;
  overflow: hidden;
}
.sheet-solid-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: var(--sheet-bg);
  z-index: 0;
}
.sheet-body {
  position: relative;
  z-index: 1;
  padding: 16rpx 40rpx calc(60rpx + env(safe-area-inset-bottom));
}
.sheet-handle {
  width: 96rpx; height: 6rpx;
  background: var(--text-tertiary);
  border-radius: 3rpx;
  margin: 0 auto 32rpx;
  opacity: 0.4;
}
.sheet-form-title {
  display: block;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}

/* 按钮 .btn-glass* 已统一定义于全局 app.wxss（去重） */

/* ===== 实时标签预览 ===== */
.form-tag-preview {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
  min-height: 48rpx;
}
.form-tag-pill {
  font-size: 24rpx;
  color: var(--text-secondary);
  background: var(--fill-subtle);
  padding: 8rpx 18rpx;
  border-radius: var(--radius-pill);
}

/* ===== placeholder 样式 ===== */
.filter-input-placeholder {
  font-size: 28rpx;
  color: var(--text-tertiary);
}

/* FIX: 平板横屏优化 */
@media (min-width: 768px) {
  .main-content {
    max-width: 680rpx;
    margin: 0 auto;
  }
  .form-row {
    gap: 24rpx;
  }
  .list-item {
    padding: 28rpx 32rpx;
  }
  .section-title {
    font-size: 34rpx;
  }
}
