<view class="container {{darkMode ? 'dark' : ''}}">
  <!-- 顶部导航 -->
  <view class="manage-header" style="padding-top: {{statusBarHeight + 12}}px;">
    <view class="back-btn tap-target" bindtap="goBack">
      <text class="back-icon">‹</text>
    </view>
    <text class="manage-title">菜品管理</text>
    <view style="width: 72rpx;"></view>
  </view>

  <view class="main-content">

    <!-- 口味画像 + 连胜 -->
    <view class="section-glass" wx:if="{{tasteProfile}}">
      <view class="section-header-row">
        <text class="section-title">口味画像</text>
        <text class="section-count">{{tasteProfile.total}} 餐</text>
      </view>
      <view style="padding: 24rpx 32rpx;">
        <text style="display:block;font-size:26rpx;color:var(--text-secondary);margin-bottom:12rpx;">{{tasteProfile.headline}}</text>
        <view wx:if="{{streak && streak.current > 0}}" style="display:flex;align-items:center;gap:12rpx;margin-bottom:16rpx;">
          <text style="font-size:28rpx;font-weight:700;color:var(--food-accent);">🔥 连续 {{streak.current}} 天一起决定</text>
          <text wx:if="{{streak.longest > streak.current}}" style="font-size:22rpx;color:var(--text-tertiary);">最长 {{streak.longest}} 天</text>
        </view>
        <view class="list-tags" wx:if="{{tasteProfile.topCategories.length}}">
          <text wx:for="{{tasteProfile.topCategories}}" wx:key="name" class="list-tag">{{item.name}} ×{{item.count}}</text>
        </view>
        <view class="list-tags" wx:if="{{tasteProfile.topTags.length}}" style="margin-top:8rpx;">
          <text wx:for="{{tasteProfile.topTags}}" wx:key="name" class="list-tag">{{item.name}}</text>
        </view>
        <view style="display:flex;gap:24rpx;margin-top:16rpx;font-size:24rpx;color:var(--text-tertiary);">
          <text>❤️ 收藏 {{tasteProfile.favoriteCount}}</text>
          <text wx:if="{{tasteProfile.total > 0}}">🌶️ 辣度偏好 {{tasteProfile.spicyPercent}}%</text>
        </view>
      </view>
    </view>

    <!-- 菜品 -->
    <view class="section-glass">
      <view class="section-header-row">
        <text class="section-title">菜品</text>
        <text class="section-count">共 {{foodCount}} 道</text>
      </view>

      <view style="padding: 24rpx 32rpx;">
        <!-- 搜索 -->
        <view class="search-bar">
          <text class="search-icon">🔍</text>
          <input class="search-input" placeholder="搜索菜名" placeholder-class="filter-input-placeholder" value="{{searchText}}" bindinput="onSearchInput" />
          <view wx:if="{{searchText}}" class="search-clear" bindtap="onClearSearch">
            <view class="icon-close" style="color:var(--text-tertiary);"></view>
          </view>
        </view>
        <!-- 分类筛选 -->
        <scroll-view scroll-x="true" class="chip-scroll" enhanced="true" show-scrollbar="false">
          <view class="chip-row">
            <view wx:for="{{categoryFilterOptions}}" wx:key="*this" class="chip {{categoryFilterIdx === index ? 'chip-active' : ''}}" bindtap="onCategoryFilter" data-index="{{index}}">{{item}}</view>
          </view>
        </scroll-view>
      </view>

      <!-- 空状态 -->
      <view wx:if="{{displayFoods.length === 0}}" class="empty-state">
        <text class="empty-text">{{searchText || categoryFilterIdx > 0 ? '没有匹配的菜品' : '还没有菜品'}}</text>
        <button wx:if="{{searchText || categoryFilterIdx > 0}}" class="btn-glass btn-glass-secondary" style="margin-top:24rpx;" bindtap="onClearSearchAndFilter">清除搜索与筛选</button>
        <button wx:else class="btn-glass" style="margin-top:24rpx;" bindtap="openAddSheet">添加第一道菜</button>
      </view>

      <!-- 列表（点击编辑） -->
      <view wx:for="{{displayFoods}}" wx:key="_id" class="list-item" bindtap="openEditSheet" data-id="{{item._id}}">
        <view class="list-item-left">
          <text class="list-emoji">{{item.emoji}}</text>
          <view>
            <text class="list-name">{{item.name}}</text>
            <view class="list-tags">
              <text class="list-tag">{{item.category}}</text>
              <text wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this" class="list-tag">{{tag}}</text>
            </view>
          </view>
        </view>
        <text class="list-edit">›</text>
      </view>
      <view wx:if="{{hasMore}}" class="list-more" bindtap="showMoreFoods">
        <text class="list-more-text">显示更多 · 还有 {{filteredCount - displayFoods.length}} 道</text>
      </view>
    </view>

    <!-- 添加菜品 -->
    <button class="btn-glass" style="width:100%;margin-bottom:24rpx;" bindtap="openAddSheet">＋ 添加菜品</button>

    <!-- 最近记录 -->
    <view class="section-glass">
      <view class="section-header-row">
        <text class="section-title">最近记录</text>
        <text class="list-delete" bindtap="clearHistory" wx:if="{{historyDisplay.length > 0}}">清空</text>
      </view>
      <view wx:if="{{historyDisplay.length === 0}}" class="empty-state">
        <text class="empty-text">还没有记录</text>
      </view>
      <view wx:for="{{historyDisplay}}" wx:key="index" class="list-item">
        <view class="list-item-left">
          <text class="list-emoji">{{item.emoji}}</text>
          <text class="list-name">{{item.name}}</text>
        </view>
        <view class="list-item-right">
          <text class="section-count">{{item.dateStr}}</text>
          <text class="list-delete" bindtap="deleteHistoryItem" data-index="{{index}}">删除</text>
        </view>
      </view>
    </view>

    <!-- 爱吃榜 -->
    <view class="section-glass">
      <view class="section-header-row">
        <text class="section-title">爱吃榜</text>
        <text class="list-delete" bindtap="clearFavorites" wx:if="{{favorites.length > 0}}">清空</text>
      </view>
      <view wx:if="{{favorites.length === 0}}" class="empty-state">
        <text class="empty-text">还没有收藏</text>
      </view>
      <view wx:for="{{favorites}}" wx:key="name" class="list-item">
        <view class="list-item-left">
          <text class="list-emoji">{{item.emoji}}</text>
          <text class="list-name">{{item.name}}</text>
        </view>
        <text class="list-delete" bindtap="removeFavorite" data-name="{{item.name}}">取消收藏</text>
      </view>
    </view>

    <!-- 数据管理 -->
    <view class="section-glass">
      <view class="section-header-row">
        <text class="section-title">数据管理</text>
      </view>
      <view class="form-row" style="padding: 24rpx 32rpx; margin:0;">
        <button class="btn-glass btn-glass-secondary" style="flex:1;" bindtap="exportData">📋 导出</button>
        <button class="btn-glass" style="flex:1;" bindtap="importData">📥 导入</button>
      </view>
    </view>
  </view>

  <!-- ===== 新增 / 编辑 Sheet ===== -->
  <view class="sheet-overlay" wx:if="{{showFoodSheet}}" bindtap="closeFoodSheet">
    <view class="sheet-content" catchtap="onModalContentTap">
      <view class="sheet-solid-bg"></view>
      <view class="sheet-body">
        <view class="sheet-handle"></view>
        <text class="sheet-form-title">{{editingId ? '编辑菜品' : '添加菜品'}}</text>
        <view class="form-row">
          <input class="form-input" placeholder="食物名称" placeholder-class="filter-input-placeholder" value="{{foodForm.name}}" bindinput="onFormName" />
          <input class="form-input" style="flex:0.5;" maxlength="2" placeholder="Emoji" placeholder-class="filter-input-placeholder" value="{{foodForm.emoji}}" bindinput="onFormEmoji" />
        </view>
        <view class="form-row">
          <picker bindchange="onFormCategory" value="{{foodForm.categoryIdx}}" range="{{categoryOptions}}" style="flex:1;">
            <view class="form-picker"><text class="form-picker-label">分类</text><text class="form-picker-value">{{categoryOptions[foodForm.categoryIdx]}}</text><text class="form-picker-chevron">›</text></view>
          </picker>
          <picker bindchange="onFormScene" value="{{foodForm.sceneIdx}}" range="{{sceneOptions}}" style="flex:1;">
            <view class="form-picker"><text class="form-picker-label">场景</text><text class="form-picker-value">{{sceneOptions[foodForm.sceneIdx]}}</text><text class="form-picker-chevron">›</text></view>
          </picker>
        </view>
        <view class="form-row">
          <picker bindchange="onFormBudget" value="{{foodForm.budgetIdx}}" range="{{budgetOptions}}" style="flex:1;">
            <view class="form-picker"><text class="form-picker-label">预算</text><text class="form-picker-value">{{budgetOptions[foodForm.budgetIdx]}}</text><text class="form-picker-chevron">›</text></view>
          </picker>
          <picker bindchange="onFormTime" value="{{foodForm.timeIdx}}" range="{{timeOptions}}" style="flex:1;">
            <view class="form-picker"><text class="form-picker-label">时间</text><text class="form-picker-value">{{timeOptions[foodForm.timeIdx]}}</text><text class="form-picker-chevron">›</text></view>
          </picker>
        </view>
        <view class="form-row">
          <input class="form-input" placeholder="标签，用逗号分隔" placeholder-class="filter-input-placeholder" value="{{foodForm.tags}}" bindinput="onFormTags" />
        </view>
        <view class="form-tag-preview" wx:if="{{foodFormTagsPreview.length > 0}}">
          <text wx:for="{{foodFormTagsPreview}}" wx:key="*this" class="form-tag-pill">{{item}}</text>
        </view>
        <button class="btn-glass" style="width:100%;margin-top:24rpx;" bindtap="saveFood">{{editingId ? '保存' : '添加'}}</button>
        <button wx:if="{{editingId}}" class="btn-danger" style="width:100%;margin-top:12rpx;" bindtap="deleteFood" data-id="{{editingId}}">删除菜品</button>
        <button class="btn-glass btn-glass-ghost" style="width:100%;margin-top:8rpx;" bindtap="closeFoodSheet">取消</button>
      </view>
    </view>
  </view>
</view>
