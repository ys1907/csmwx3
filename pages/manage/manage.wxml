<view class="container">
  <!-- 背景光斑 -->
  <view class="bg-orb bg-orb-1"></view>
  <view class="bg-orb bg-orb-2"></view>

  <!-- 顶部导航 -->
  <view class="manage-header" style="padding-top: {{statusBarHeight + 12}}px;">
    <view class="back-btn" bindtap="goBack">
      <text class="back-icon">‹</text>
    </view>
    <text class="manage-title">管理</text>
    <view style="width: 72rpx;"></view>
  </view>

  <view class="main-content">
    <!-- 添加食物 -->
    <view class="section-glass">
      <view class="section-header-row">
        <text class="section-title">添加食物</text>
      </view>
      <view class="form-glass">
        <view class="form-row">
          <input type="text" placeholder="食物名称" placeholder-class="filter-input-placeholder" value="{{newFood.name}}" bindinput="onNewFoodName" class="form-input"/>
          <input type="text" placeholder="Emoji" maxlength="2" placeholder-class="filter-input-placeholder" value="{{newFood.emoji}}" bindinput="onNewFoodEmoji" class="form-input" style="flex:0.5;"/>
        </view>
        <view class="form-row">
          <picker bindchange="onNewFoodCategory" value="{{newFood.categoryIdx}}" range="{{categoryOptions}}" style="flex: 1;">
            <view class="form-picker">
              <text class="form-picker-label">分类</text>
              <text class="form-picker-value">{{categoryOptions[newFood.categoryIdx]}}</text>
            </view>
          </picker>
          <picker bindchange="onNewFoodScene" value="{{newFood.sceneIdx}}" range="{{sceneOptions}}" style="flex: 1;">
            <view class="form-picker">
              <text class="form-picker-label">场景</text>
              <text class="form-picker-value">{{sceneOptions[newFood.sceneIdx]}}</text>
            </view>
          </picker>
        </view>
        <view class="form-row">
          <picker bindchange="onNewFoodBudget" value="{{newFood.budgetIdx}}" range="{{budgetOptions}}" style="flex: 1;">
            <view class="form-picker">
              <text class="form-picker-label">预算</text>
              <text class="form-picker-value">{{budgetOptions[newFood.budgetIdx]}}</text>
            </view>
          </picker>
          <picker bindchange="onNewFoodTime" value="{{newFood.timeIdx}}" range="{{timeOptions}}" style="flex: 1;">
            <view class="form-picker">
              <text class="form-picker-label">时间</text>
              <text class="form-picker-value">{{timeOptions[newFood.timeIdx]}}</text>
            </view>
          </picker>
        </view>
        <view class="form-row">
          <input type="text" placeholder="标签，用逗号分隔" placeholder-class="filter-input-placeholder" value="{{newFood.tags}}" bindinput="onNewFoodTags" class="form-input"/>
        </view>
        <view class="form-row" style="margin-bottom:0;margin-top:8rpx;">
          <button class="btn-glass btn-glass-secondary" style="width:100%;" bindtap="addFood">添加自定义食物</button>
        </view>
      </view>
    </view>

    <!-- 食物列表 -->
    <view class="section-glass">
      <view class="section-header-row">
        <text class="section-title">食物列表</text>
        <text class="section-count">{{foodCount}}</text>
      </view>
      <view wx:if="{{foods.length === 0}}" class="empty-state">
        <text class="empty-text">还没有自定义食物</text>
      </view>
      <view wx:for="{{foods}}" wx:key="_id" class="list-item">
        <view class="list-item-left">
          <text class="list-emoji">{{item.emoji}}</text>
          <view>
            <text class="list-name">{{item.name}}</text>
            <view class="list-tags" wx:if="{{item.tags && item.tags.length}}">
              <text wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this" class="list-tag">{{tag}}</text>
            </view>
          </view>
        </view>
        <text class="list-delete" bindtap="deleteFood" data-id="{{item._id}}">删除</text>
      </view>
    </view>

    <!-- 最近记录 -->
    <view class="section-glass">
      <view class="section-header-row">
        <text class="section-title">最近记录</text>
        <text class="list-delete" bindtap="clearHistory" wx:if="{{historyDisplay.length > 0}}">清空</text>
      </view>
      <view wx:if="{{historyDisplay.length === 0}}" class="empty-state">
        <text class="empty-text">还没有记录</text>
      </view>
      <view wx:for="{{historyDisplay}}" wx:key="date" class="list-item">
        <view class="list-item-left">
          <text class="list-emoji">{{item.emoji}}</text>
          <text class="list-name">{{item.name}}</text>
        </view>
        <text class="section-count">{{item.dateStr}}</text>
      </view>
    </view>

    <!-- 爱吃榜 -->
    <view class="section-glass">
      <view class="section-header-row">
        <text class="section-title">爱吃榜</text>
        <text class="list-delete" bindtap="clearFavorites" wx:if="{{favorites.length > 0}}">清空</text>
      </view>
      <view wx:if="{{favorites.length === 0}}" class="empty-state">
        <text class="empty-text">还没有收藏</text>
      </view>
      <view wx:for="{{favorites}}" wx:key="name" class="list-item">
        <view class="list-item-left">
          <text class="list-emoji">{{item.emoji}}</text>
          <text class="list-name">{{item.name}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
