<view class="container {{darkMode ? 'dark' : ''}}">
  <!-- 启动页 -->
  <view class="intro-glass {{introFading ? 'fading' : ''}}" wx:if="{{showIntro}}">
    <view class="intro-orb"><text class="intro-orb-inner">🍽️</text></view>
    <text class="intro-title-glass">今天吃什么</text>
    <text class="intro-sub-glass">给你们的一餐建议</text>
  </view>

  <!-- ============ 推荐 tab：盲盒 ============ -->
  <view hidden="{{activeTab !== 'home'}}" class="home">
    <view class="topbar">
      <view class="topbar-text">
        <text class="app-title">今天吃什么</text>
        <text class="app-date">{{headerDate}}</text>
      </view>
      <view class="gear tap-target" bindtap="openFilterSheet">
        <view class="gear-dot" wx:if="{{hasActiveFilters}}"></view>⚙
      </view>
    </view>

    <view class="stage {{auraClass}}">
      <!-- 盲盒态（待揭晓 / 揭晓动画中） -->
      <view wx:if="{{boxPhase !== 'revealed'}}"
            class="boxcard {{boxPhase === 'revealing' ? 'reveal-' + revealRarity : ''}}"
            bindtap="onTapBox">
        <view class="box-glow"></view>
        <text class="box-emoji">🎁</text>
        <text class="box-tip">轻触揭晓今天的命运</text>
        <view class="box-dots"><view></view><view></view><view></view></view>
      </view>

      <!-- 揭晓态：① 菜卡（内容）② 操作（卡外） -->
      <block wx:if="{{boxPhase === 'revealed'}}">
        <view class="dishcard rarity-{{revealRarity}}">
          <view class="fav-corner" catchtap="onToggleFav">{{currentResultIsFav ? '♥' : '♡'}}</view>
          <view class="rarity-badge badge-{{revealRarity}}">{{revealRarity}}</view>
          <text class="crown" wx:if="{{revealRarity === 'SSR'}}">👑</text>
          <block wx:if="{{revealRarity === 'SSR'}}">
            <view class="spark spark-a"></view>
            <view class="spark spark-b"></view>
            <view class="spark spark-c"></view>
            <view class="spark spark-d"></view>
            <view class="spark spark-e"></view>
            <view class="spark spark-f"></view>
            <view class="spark spark-g"></view>
            <view class="spark spark-h"></view>
            <view class="spark spark-i"></view>
          </block>
          <text class="dish-emoji">{{currentResult.emoji}}</text>
          <text class="dish-name">{{currentResult.name}}</text>
          <text class="dish-reason">{{resultReason}}</text>
          <view class="dish-tags">
            <text class="tag-pill warm">{{currentResult.time === '快' ? '约 15 分钟' : '约 30 分钟'}}</text>
            <text class="tag-pill mint">{{currentResult.scene}}</text>
          </view>
        </view>
        <view class="dish-actions">
          <view class="btn-eat" hover-class="btn-eat-hover" hover-stay-time="70" bindtap="onConfirmEat">就吃这个</view>
          <view class="btn-retry" hover-class="btn-retry-hover" hover-stay-time="70" bindtap="onRetry">↻ 换一个</view>
        </view>
        <text class="share-link" hover-class="share-link-hover" hover-stay-time="70" bindtap="onShareResult">📤 生成分享卡片</text>
      </block>

      <!-- 凑一桌入口：按用户要求暂时隐藏（buildCombo 与凑一桌 Sheet 的代码保留，恢复时取消注释即可） -->
      <!-- <view wx:if="{{boxPhase === 'idle'}}" class="combo-entry" hover-class="combo-entry-hover" hover-stay-time="70" bindtap="buildCombo">🍱 两个人？帮你们凑一桌</view> -->
    </view>
  </view>

  <!-- ============ 我的 tab ============ -->
  <view hidden="{{activeTab !== 'mine'}}" class="mine">
    <view class="mine-header"><text class="app-title">我的</text></view>
    <view class="mine-card streak-card" wx:if="{{mineStreak}}">
      <text class="streak-num">{{mineStreak.current}}</text>
      <text class="streak-label">天连续决定 · 最长 {{mineStreak.longest}} 天</text>
    </view>
    <view class="mine-card" wx:if="{{mineProfile}}">
      <text class="mine-sec">口味画像</text>
      <text class="mine-headline">{{mineProfile.headline}}</text>
    </view>
    <view class="mine-card">
      <text class="mine-sec">✨ SSR 图鉴（{{mineSsrDex.length}}）</text>
      <view wx:if="{{mineSsrDex.length === 0}}" class="mine-empty">还没抽到 SSR，继续开盲盒碰碰运气 ✨</view>
      <view class="dex-grid">
        <view wx:for="{{mineSsrDex}}" wx:key="name" class="dex-card">
          <view class="dex-badge">SSR</view>
          <text class="dex-emoji">{{item.emoji}}</text>
          <text class="dex-name">{{item.name}}</text>
          <text class="dex-date">{{item.dateStr}}</text>
        </view>
      </view>
    </view>
    <view class="mine-card">
      <text class="mine-sec">爱吃榜（{{mineFavorites.length}}）</text>
      <view wx:if="{{mineFavorites.length === 0}}" class="mine-empty">还没有收藏，揭晓后点 ♥ 收藏吧</view>
      <view wx:for="{{mineFavorites}}" wx:key="name" class="mine-row"><text class="mine-row-main">{{item.emoji}} {{item.name}}</text></view>
    </view>
    <view class="mine-card">
      <text class="mine-sec">最近吃过</text>
      <view wx:if="{{mineHistory.length === 0}}" class="mine-empty">还没有记录</view>
      <view wx:for="{{mineHistory}}" wx:key="date" class="mine-row">
        <text class="mine-row-main">{{item.emoji}} {{item.name}}</text>
        <text class="mine-row-date">{{item.dateStr}}</text>
      </view>
    </view>
    <view class="mine-entry" hover-class="mine-entry-hover" hover-stay-time="70" bindtap="goToManage">管理菜品库 ›</view>
  </view>

  <!-- ============ 底部 tab ============ -->
  <view class="tabbar">
    <view class="tab {{activeTab === 'home' ? 'on' : ''}}" bindtap="switchTab" data-tab="home"><text class="tab-ic">🎁</text>推荐</view>
    <view class="tab {{activeTab === 'mine' ? 'on' : ''}}" bindtap="switchTab" data-tab="mine"><text class="tab-ic">♡</text>我的</view>
  </view>

  <!-- ===== 筛选 Sheet ===== -->
  <view class="sheet-overlay" wx:if="{{showFilterSheet}}" bindtap="closeFilterSheet">
    <view class="sheet" catchtap="onModalContentTap">
      <view class="sheet-handle"></view>
      <view class="sheet-head">
        <text class="sheet-action" bindtap="closeFilterSheet">取消</text>
        <text class="sheet-title">筛选</text>
        <text class="sheet-action primary {{hasActiveFilters ? 'active' : ''}}" bindtap="onResetFromSheet">重置</text>
      </view>
      <view class="filter-row" bindtap="openScenePicker"><text class="filter-label">场景</text><view class="filter-val {{filters.sceneIdx > 0 ? 'active' : ''}}"><text>{{sceneOptions[filters.sceneIdx]}}</text><text class="chev">›</text></view></view>
      <view class="filter-row" bindtap="openBudgetPicker"><text class="filter-label">预算</text><view class="filter-val {{filters.budgetIdx > 0 ? 'active' : ''}}"><text>{{budgetOptions[filters.budgetIdx]}}</text><text class="chev">›</text></view></view>
      <view class="filter-row" bindtap="openTimePicker"><text class="filter-label">时间</text><view class="filter-val {{filters.timeIdx > 0 ? 'active' : ''}}"><text>{{timeOptions[filters.timeIdx]}}</text><text class="chev">›</text></view></view>
      <view class="filter-row" bindtap="openTastePicker"><text class="filter-label">口味</text><view class="filter-val {{filters.tasteIdx > 0 ? 'active' : ''}}"><text>{{tasteOptions[filters.tasteIdx]}}</text><text class="chev">›</text></view></view>
      <view class="filter-row" bindtap="openAvoidPicker"><text class="filter-label">避免</text><view class="filter-val {{filters.avoid ? 'active' : ''}}"><text>{{filters.avoid || '未选择'}}</text><text class="chev">›</text></view></view>
      <view class="toggle-row"><text class="filter-label">排除最近 3 天</text><view class="toggle {{excludeRecent ? 'on' : ''}}" bindtap="onToggleExclude"></view></view>
      <view class="btn-eat sheet-apply" bindtap="closeFilterSheet">应用筛选</view>
    </view>
  </view>

  <!-- ===== 选择器 Sheet ===== -->
  <view class="sheet-overlay" wx:if="{{showPickerSheet}}" bindtap="closePickerSheet">
    <view class="sheet" catchtap="onModalContentTap">
      <view class="sheet-handle"></view>
      <text class="sheet-title">{{pickerTitle}}</text>
      <view class="picker-list">
        <view wx:for="{{pickerOptions}}" wx:key="*this" class="picker-item {{pickerActiveIdx === index ? 'active' : ''}}" bindtap="onPickerSelect" data-index="{{index}}">
          <text>{{item}}</text>
          <text class="check" wx:if="{{pickerActiveIdx === index}}">✓</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ===== 凑一桌 Sheet ===== -->
  <view class="sheet-overlay {{comboClosing ? 'out' : ''}}" wx:if="{{showCombo}}" bindtap="closeCombo">
    <view class="sheet {{comboClosing ? 'out' : ''}}" catchtap="onModalContentTap">
      <view class="sheet-handle"></view>
      <text class="sheet-title">🍱 一桌好菜</text>
      <text class="sheet-sub">为你们凑了 {{comboResult.length}} 道，荤素搭配更尽兴</text>
      <view wx:for="{{comboResult}}" wx:key="name" class="combo-row">
        <text class="combo-emoji">{{item.emoji}}</text>
        <view class="combo-info">
          <text class="combo-name">{{item.name}}</text>
          <view class="dish-tags"><text class="tag-pill warm">{{item.category}}</text><text class="tag-pill mint">{{item.budget}}</text></view>
        </view>
      </view>
      <view class="sheet-actions">
        <view class="btn-eat" hover-class="btn-eat-hover" hover-stay-time="70" bindtap="closeCombo">就这桌了</view>
        <view class="btn-retry" hover-class="btn-retry-hover" hover-stay-time="70" bindtap="buildCombo">↻ 换一桌</view>
      </view>
    </view>
  </view>

  <!-- 分享卡片 Canvas（仅生成时挂载） -->
  <canvas wx:if="{{shareCanvasMounted}}" type="2d" id="shareCanvas" style="position:fixed;left:-9999px;top:-9999px;width:600px;height:800px;"></canvas>
</view>
