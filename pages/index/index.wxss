/** pages/index/index.wxss — 盲盒首页（奶油恋人） **/

/* ===== 启动页 ===== */
.intro-glass {
  position: fixed; inset: 0; z-index: 999;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  background: var(--page-bg);
  animation: fadeIn 0.3s ease;
}
.intro-glass.fading { opacity: 0; transition: opacity 0.3s ease; }
.intro-orb {
  width: 160rpx; height: 160rpx; border-radius: 50%;
  background: var(--card-bg); box-shadow: var(--shadow-soft);
  display: flex; align-items: center; justify-content: center;
  animation: boxFloat 3s ease-in-out infinite;
}
.intro-orb-inner { font-size: 80rpx; }
.intro-title-glass { margin-top: 36rpx; font-size: 44rpx; font-weight: 700; color: var(--text-primary); }
.intro-sub-glass { margin-top: 12rpx; font-size: 26rpx; color: var(--text-secondary); }

/* ===== 推荐 tab ===== */
.home { display: flex; flex-direction: column; min-height: 100vh; padding-bottom: 124rpx; }
.topbar { display: flex; justify-content: space-between; align-items: center; padding: calc(env(safe-area-inset-top) + 150rpx) 44rpx 8rpx; }
.app-title { font-size: 44rpx; font-weight: 700; color: var(--text-primary); letter-spacing: -0.5rpx; }
.app-date { display: block; font-size: 24rpx; color: var(--text-secondary); margin-top: 6rpx; }
.gear {
  position: relative; width: 76rpx; height: 76rpx; border-radius: 50%;
  background: var(--card-bg); box-shadow: var(--shadow-card);
  display: flex; align-items: center; justify-content: center; font-size: 32rpx; color: var(--text-secondary);
}
.gear-dot { position: absolute; top: 14rpx; right: 14rpx; width: 14rpx; height: 14rpx; border-radius: 50%; background: var(--primary); }

.stage { position: relative; flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: flex-start; padding: 80rpx 64rpx 40rpx; gap: 40rpx; }
.stage.aura-SSR::before {
  content: ''; position: absolute; inset: 0; z-index: 0; pointer-events: none;
  background: radial-gradient(circle at 50% 42%, rgba(255,236,200,0) 26%, rgba(255,206,150,0.42) 60%, rgba(235,169,196,0.42) 86%, rgba(201,139,255,0.30) 100%);
  animation: auraIn 0.6s ease forwards;
}
@keyframes auraIn { from { opacity: 0; } to { opacity: 1; } }

/* ===== 盲盒卡 ===== */
.boxcard {
  position: relative; z-index: 1; width: 100%; height: 720rpx; border-radius: 56rpx;
  background: var(--card-bg); box-shadow: var(--shadow-soft);
  display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 24rpx;
  animation: boxFloat 3.4s ease-in-out infinite;
}
.box-glow {
  position: absolute; inset: -24rpx; border-radius: 72rpx; z-index: -1;
  background: radial-gradient(circle at 50% 42%, var(--primary-soft), rgba(235,169,196,0.16) 55%, transparent 72%);
  filter: blur(16rpx); animation: boxPulse 3.4s ease-in-out infinite;
}
.box-emoji { font-size: 170rpx; line-height: 1; }
.box-tip { font-size: 30rpx; font-weight: 600; color: var(--primary); }
.box-dots { display: flex; gap: 10rpx; }
.box-dots view { width: 12rpx; height: 12rpx; border-radius: 50%; background: var(--primary); animation: blink 1.4s infinite; }
.box-dots view:nth-child(2) { animation-delay: 0.2s; }
.box-dots view:nth-child(3) { animation-delay: 0.4s; }
@keyframes boxFloat { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-16rpx); } }
@keyframes boxPulse { 0%,100% { opacity: 0.5; transform: scale(0.98); } 50% { opacity: 1; transform: scale(1.04); } }
@keyframes blink { 0%,100% { opacity: 0.25; } 50% { opacity: 0.9; } }

/* ===== 三档揭晓动画（盒子阶段） ===== */
.boxcard.reveal-R { animation: rRise 0.9s cubic-bezier(0.34,1.4,0.64,1) forwards; }
@keyframes rRise {
  0% { transform: scale(1); opacity: 1; }
  35% { transform: scale(1.06); opacity: 1; }
  100% { transform: scale(0.4); opacity: 0; }
}
.boxcard.reveal-SR { animation: charge 1.1s ease-in-out, goldVanish 0.5s ease-in 1.1s forwards; }
.boxcard.reveal-SSR { animation: charge2 2s ease-in-out, goldVanish 0.6s ease-in 2s forwards; }
@keyframes charge {
  0%,100% { transform: scale(1) rotate(0); }
  20% { transform: scale(0.93) rotate(-3deg); }
  40% { transform: scale(1.05) rotate(3deg); }
  60% { transform: scale(0.95) rotate(-2deg); }
  80% { transform: scale(1.04) rotate(2deg); }
}
@keyframes charge2 {
  0%,100% { transform: scale(1) rotate(0); }
  15% { transform: scale(0.9) rotate(-4deg); }
  35% { transform: scale(1.1) rotate(4deg); }
  55% { transform: scale(0.92) rotate(-3deg); }
  75% { transform: scale(1.12) rotate(3deg); }
  90% { transform: scale(0.95); }
}
@keyframes goldVanish {
  0% { box-shadow: var(--shadow-soft); }
  40% { box-shadow: 0 0 120rpx 50rpx var(--gold-light); transform: scale(1.12); opacity: 1; }
  100% { transform: scale(0.2); opacity: 0; }
}

/* ===== 揭晓菜卡 ===== */
.dishcard {
  position: relative; z-index: 1; width: 100%; min-height: 720rpx; box-sizing: border-box;
  background: var(--card-bg); border-radius: 56rpx; padding: 72rpx 44rpx 64rpx;
  box-shadow: var(--shadow-soft); text-align: center;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
}
.fav-corner {
  position: absolute; top: 32rpx; left: 32rpx; width: 76rpx; height: 76rpx; border-radius: 50%;
  background: var(--pink-soft); display: flex; align-items: center; justify-content: center; font-size: 38rpx; color: #D17EA8;
}
.rarity-badge {
  position: absolute; top: 40rpx; right: 32rpx; z-index: 3;
  font-size: 22rpx; font-weight: 800; letter-spacing: 2rpx; padding: 8rpx 20rpx; border-radius: 999rpx; color: #fff;
}
.badge-R { background: #B8ADA3; }
.badge-SR { background: linear-gradient(135deg, var(--gold), var(--gold-deep)); box-shadow: 0 4rpx 14rpx rgba(245,166,35,0.4); }
.badge-SSR {
  background: linear-gradient(90deg, #ff9a9a, #ffd86b, #7affc3, #6bb7ff, #c98bff, #ff9a9a);
  background-size: 300% 100%; animation: holoBadge 3s linear infinite;
  border: 2rpx solid var(--gold-light); box-shadow: 0 4rpx 16rpx rgba(245,166,35,0.45), inset 0 0 8rpx rgba(255,255,255,0.6);
}
@keyframes holoBadge { to { background-position: 300% 0; } }
.spark { position: absolute; width: 20rpx; height: 20rpx; border-radius: 50%; background: radial-gradient(circle, #fff, var(--gold)); box-shadow: 0 0 20rpx var(--gold-light); z-index: 2; opacity: 0; pointer-events: none; }
.rarity-SSR .spark-a { top: 8%; left: 12%; animation: twinkle 1.8s ease-in-out infinite 0.2s; }
.rarity-SSR .spark-b { top: 14%; right: 10%; animation: twinkle 1.8s ease-in-out infinite 0.6s; }
.rarity-SSR .spark-c { bottom: 16%; left: 10%; animation: twinkle 1.8s ease-in-out infinite 0.9s; }
.rarity-SSR .spark-d { bottom: 12%; right: 14%; animation: twinkle 1.8s ease-in-out infinite 1.2s; }
.rarity-SSR .spark-e { top: 42%; left: 5%; animation: twinkle 1.8s ease-in-out infinite 0.4s; }
.rarity-SSR .spark-f { top: 24%; right: 5%; animation: twinkle 1.8s ease-in-out infinite 0.7s; }
.rarity-SSR .spark-g { bottom: 30%; right: 7%; animation: twinkle 1.8s ease-in-out infinite 1.0s; }
.rarity-SSR .spark-h { top: 62%; left: 7%; animation: twinkle 1.8s ease-in-out infinite 0.3s; }
.rarity-SSR .spark-i { bottom: 24%; left: 18%; animation: twinkle 1.8s ease-in-out infinite 1.4s; }
@keyframes twinkle { 0%,100% { opacity: 0; transform: scale(0.4); } 50% { opacity: 1; transform: scale(1.3); } }
.dish-emoji { font-size: 168rpx; line-height: 1; }
.dish-name { display: block; font-size: 52rpx; font-weight: 700; margin-top: 24rpx; color: var(--text-primary); letter-spacing: -0.5rpx; }
.dish-reason { display: block; font-size: 26rpx; color: var(--text-secondary); margin-top: 18rpx; }
.dish-tags { display: flex; gap: 16rpx; justify-content: center; margin-top: 32rpx; }
.tag-pill { font-size: 22rpx; padding: 8rpx 22rpx; border-radius: 999rpx; font-weight: 600; }
.tag-pill.warm { background: #FFF0E6; color: var(--primary-deep); }
.tag-pill.mint { background: var(--mint-soft); color: #3FA98C; }

.dishcard.rarity-R { animation: dishRise 0.6s cubic-bezier(0.34,1.5,0.6,1); }
@keyframes dishRise { 0% { transform: scale(0.4); opacity: 0; } 60% { transform: scale(1.04); opacity: 1; } 100% { transform: scale(1); opacity: 1; } }
.dishcard.rarity-SR { box-shadow: 0 18rpx 46rpx rgba(245,166,35,0.28), 0 0 0 4rpx var(--gold-light); animation: dishPop 0.6s cubic-bezier(0.34,1.56,0.64,1); }
.dishcard.rarity-SSR {
  border: 8rpx solid transparent;
  background:
    linear-gradient(var(--card-bg), var(--card-bg)) padding-box,
    conic-gradient(from 0deg, #ff9a9a, #ffd86b, #7affc3, #6bb7ff, #c98bff, #ff9a9a) border-box;
  box-shadow: 0 0 56rpx 6rpx rgba(255,195,107,0.55), 0 0 120rpx 28rpx rgba(235,169,196,0.38), 0 20rpx 50rpx rgba(245,166,35,0.30);
  animation: dishPop 0.7s cubic-bezier(0.34,1.56,0.64,1) 0.1s backwards;
}
.dishcard.rarity-SSR::before {
  content: ''; position: absolute; inset: -28rpx; border-radius: 84rpx; z-index: -1;
  background: radial-gradient(circle, transparent 56%, rgba(255,206,150,0.5) 70%, rgba(201,139,255,0.28) 86%, transparent 98%);
  filter: blur(8rpx); animation: ssrAura 2.4s ease-in-out infinite;
}
@keyframes ssrAura { 0%,100% { opacity: 0.55; transform: scale(0.97); } 50% { opacity: 1; transform: scale(1.05); } }
.dishcard.rarity-SSR::after {
  content: ''; position: absolute; inset: -22rpx; border-radius: 78rpx; z-index: -1;
  border: 3rpx dashed var(--gold-deep); opacity: 0.5;
  animation: ringSpin 9s linear infinite;
}
@keyframes ringSpin { to { transform: rotate(360deg); } }
@keyframes dishPop { 0% { transform: scale(0.3); opacity: 0; } 60% { transform: scale(1.12); opacity: 1; } 100% { transform: scale(1); opacity: 1; } }
.rarity-SR .dish-emoji { animation: emojiBounce 0.6s cubic-bezier(0.34,1.7,0.5,1) 0.1s; }
@keyframes emojiBounce { 0% { transform: scale(1); } 40% { transform: scale(1.3) translateY(-12rpx); } 100% { transform: scale(1); } }
.rarity-SSR .dish-emoji { animation: emojiBig 0.8s cubic-bezier(0.34,1.7,0.5,1) 0.3s; }
@keyframes emojiBig { 0% { transform: scale(1) rotate(0); } 30% { transform: scale(1.4) translateY(-16rpx) rotate(-8deg); } 60% { transform: scale(1.15) rotate(5deg); } 100% { transform: scale(1) rotate(0); } }
/* SSR 全息彩虹镀边 + 皇冠 */
.holo { display: none; }
.crown { position: absolute; top: -34rpx; left: 50%; transform: translateX(-50%); font-size: 66rpx; z-index: 3; animation: crownDrop 0.7s cubic-bezier(0.34,1.6,0.5,1) 0.4s backwards; }
@keyframes crownDrop {
  0% { opacity: 0; transform: translateX(-50%) translateY(-40rpx) scale(0) rotate(-20deg); }
  60% { opacity: 1; transform: translateX(-50%) translateY(-4rpx) scale(1.2) rotate(8deg); }
  100% { opacity: 1; transform: translateX(-50%) translateY(0) scale(1) rotate(0); }
}

/* ===== 卡外操作 ===== */
.dish-actions { display: flex; flex-direction: column; align-items: center; gap: 12rpx; }
.btn-eat {
  display: inline-flex; align-items: center; justify-content: center; min-height: 96rpx; padding: 0 108rpx;
  border-radius: 48rpx; font-size: 32rpx; font-weight: 700; color: #fff;
  background: linear-gradient(135deg, var(--primary), var(--primary-deep)); box-shadow: 0 20rpx 44rpx var(--primary-soft);
}
.btn-eat:active { transform: scale(0.97); }
.btn-retry { display: inline-flex; align-items: center; justify-content: center; gap: 6rpx; min-height: 64rpx; font-size: 28rpx; font-weight: 600; color: var(--text-secondary); }
.btn-retry:active { opacity: 0.6; }
.share-link { font-size: 24rpx; color: var(--text-tertiary); }

.combo-entry {
  font-size: 28rpx; font-weight: 600; color: var(--text-secondary);
  padding: 22rpx 44rpx; border-radius: 999rpx; background: var(--card-bg); box-shadow: var(--shadow-card);
}
.combo-entry:active { transform: scale(0.97); }

/* ===== 底部 tab ===== */
.tabbar {
  position: fixed; left: 0; right: 0; bottom: 0; height: 124rpx;
  border-top: 1rpx solid var(--separator); background: var(--card-bg);
  display: flex; align-items: center; justify-content: space-around;
  padding-bottom: env(safe-area-inset-bottom);
}
.tab { display: flex; flex-direction: column; align-items: center; gap: 4rpx; font-size: 24rpx; color: var(--text-secondary); }
.tab-ic { font-size: 40rpx; }
.tab.on { color: var(--primary); font-weight: 600; }

/* ===== 我的 tab ===== */
.mine { padding: calc(env(safe-area-inset-top) + 150rpx) 44rpx 160rpx; display: flex; flex-direction: column; gap: 24rpx; }
.mine-header .app-title { font-size: 44rpx; font-weight: 700; }
.mine-card { background: var(--card-bg); border-radius: 36rpx; padding: 36rpx; box-shadow: var(--shadow-card); }
.streak-card { display: flex; align-items: baseline; gap: 14rpx; }
.streak-num { font-size: 72rpx; font-weight: 700; color: var(--primary); }
.streak-label { font-size: 24rpx; color: var(--text-secondary); }
.mine-sec { display: block; font-size: 28rpx; font-weight: 700; color: var(--text-primary); margin-bottom: 18rpx; }
.mine-headline { font-size: 26rpx; color: var(--text-secondary); line-height: 1.6; }
.mine-empty { font-size: 26rpx; color: var(--text-tertiary); }
.mine-row { display: flex; justify-content: space-between; align-items: center; padding: 18rpx 0; border-top: 1rpx solid var(--separator); }
.mine-row:first-of-type { border-top: none; }
.mine-row-main { font-size: 28rpx; color: var(--text-primary); }
.mine-row-date { font-size: 24rpx; color: var(--text-tertiary); }
.mine-entry { text-align: center; font-size: 28rpx; font-weight: 600; color: var(--primary); padding: 30rpx; background: var(--card-bg); border-radius: 36rpx; box-shadow: var(--shadow-card); }
.mine-entry:active { transform: scale(0.98); }

/* SSR 图鉴：彩虹边卡片网格 */
.dex-grid { display: flex; flex-wrap: wrap; gap: 18rpx; margin-top: 8rpx; }
.dex-card {
  width: calc((100% - 36rpx) / 3); box-sizing: border-box;
  border: 3rpx solid transparent;
  background:
    linear-gradient(var(--card-bg), var(--card-bg)) padding-box,
    conic-gradient(from 0deg, #ff9a9a, #ffd86b, #7affc3, #6bb7ff, #c98bff, #ff9a9a) border-box;
  border-radius: 24rpx; padding: 22rpx 8rpx 16rpx; text-align: center; position: relative;
  box-shadow: 0 6rpx 18rpx rgba(245,166,35,0.18);
}
.dex-badge { position: absolute; top: 8rpx; right: 8rpx; font-size: 16rpx; font-weight: 800; color: #fff; background: linear-gradient(90deg, #F5A623, #c98bff); padding: 2rpx 10rpx; border-radius: 999rpx; }
.dex-emoji { font-size: 56rpx; line-height: 1; }
.dex-name { display: block; font-size: 22rpx; font-weight: 600; color: var(--text-primary); margin-top: 8rpx; }
.dex-date { display: block; font-size: 18rpx; color: var(--text-tertiary); margin-top: 4rpx; }

/* ===== Sheet（筛选 / 选择器 / 凑一桌） ===== */
.sheet-overlay { position: fixed; inset: 0; z-index: 200; background: rgba(0,0,0,0.4); display: flex; align-items: flex-end; animation: fadeIn 0.2s ease; }
.sheet-overlay.out { animation: fadeIn 0.2s ease reverse; }
.sheet {
  width: 100%; background: var(--sheet-bg); border-radius: 40rpx 40rpx 0 0;
  padding: 24rpx 44rpx calc(48rpx + env(safe-area-inset-bottom)); animation: sheetSlideUp 0.3s cubic-bezier(0.16,1,0.3,1);
}
.sheet.out { animation: sheetSlideUp 0.22s ease reverse forwards; }
.sheet-handle { width: 72rpx; height: 8rpx; border-radius: 999rpx; background: var(--separator); margin: 0 auto 28rpx; }
.sheet-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16rpx; }
.sheet-action { font-size: 28rpx; color: var(--text-secondary); }
.sheet-action.primary { color: var(--text-tertiary); }
.sheet-action.primary.active { color: var(--primary); font-weight: 600; }
.sheet-title { font-size: 34rpx; font-weight: 700; color: var(--text-primary); text-align: center; }
.sheet-sub { display: block; font-size: 24rpx; color: var(--text-secondary); text-align: center; margin: 8rpx 0 20rpx; }
.filter-row { display: flex; justify-content: space-between; align-items: center; padding: 26rpx 0; border-bottom: 1rpx solid var(--separator); }
.filter-label { font-size: 30rpx; color: var(--text-primary); }
.filter-val { display: flex; align-items: center; gap: 8rpx; font-size: 28rpx; color: var(--text-tertiary); }
.filter-val.active { color: var(--primary); font-weight: 600; }
.chev { font-size: 30rpx; }
.toggle-row { display: flex; justify-content: space-between; align-items: center; padding: 28rpx 0; }
.toggle { width: 88rpx; height: 52rpx; border-radius: 999rpx; background: var(--fill-hover); position: relative; transition: background var(--transition-base); }
.toggle::after { content: ''; position: absolute; top: 4rpx; left: 4rpx; width: 44rpx; height: 44rpx; border-radius: 50%; background: #fff; box-shadow: var(--shadow-card); transition: transform var(--transition-base); }
.toggle.on { background: var(--primary); }
.toggle.on::after { transform: translateX(36rpx); }
.sheet-apply { width: 100%; margin-top: 32rpx; }
.picker-list { margin-top: 16rpx; }
.picker-item { display: flex; justify-content: space-between; align-items: center; padding: 28rpx 8rpx; font-size: 30rpx; color: var(--text-primary); border-bottom: 1rpx solid var(--separator); }
.picker-item.active { color: var(--primary); font-weight: 600; }
.check { color: var(--primary); }
.combo-row { display: flex; align-items: center; gap: 24rpx; padding: 22rpx 0; border-bottom: 1rpx solid var(--separator); }
.combo-emoji { font-size: 64rpx; }
.combo-info { flex: 1; }
.combo-name { display: block; font-size: 30rpx; font-weight: 600; color: var(--text-primary); margin-bottom: 10rpx; }
.sheet-actions { display: flex; flex-direction: column; align-items: center; gap: 14rpx; margin-top: 32rpx; }

.tap-target { min-width: 76rpx; min-height: 76rpx; }
