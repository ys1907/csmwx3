/** pages/index/index.wxss — iOS 26 Liquid Glass **/

/* 背景光斑已移除（减少装饰，聚焦主任务） */

/* ===== 顶部区域 ===== */
.page-header {
  position: relative;
  z-index: 10;
  padding: 140rpx 40rpx 40rpx;
}
.header-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}
.header-text {
  flex: 1;
}
.page-header-title {
  font-size: 44rpx;
  font-weight: 700;
  letter-spacing: -0.5rpx;
  color: var(--text-primary);
  line-height: 1.2;
  display: block;
}
.page-header-date {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-top: 8rpx;
  display: block;
}
.manage-entry {
  width: 72rpx;
  height: 72rpx;
  background: var(--glass-bg);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 50%;
  border: 1rpx solid var(--glass-border);
  box-shadow: var(--shadow-soft);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 8rpx;
  transition: all 0.15s ease;
}
.manage-entry:active {
  transform: scale(0.92);
  opacity: 0.8;
}
.manage-entry-icon {
  font-size: 32rpx;
}

/* Segmented Control 已移除（改为推荐优先 + 玩法宫格） */

/* ===== 主内容区 ===== */
.main-content {
  position: relative;
  z-index: 10;
  padding: 0 40rpx 40rpx;
}

/* ===== 大推荐卡片（星期/转盘共用） ===== */
.hero-card {
  background: var(--glass-bg-strong);
  backdrop-filter: blur(60rpx);
  -webkit-backdrop-filter: blur(60rpx);
  border-radius: var(--radius-xl);
  border: 1rpx solid var(--glass-border);
  box-shadow: var(--glass-highlight), var(--shadow-glass);
  padding: 56rpx 40rpx;
  text-align: center;
  margin-bottom: 32rpx;
  animation: fadeScale 0.5s var(--transition-base) both;
}
.hero-emoji {
  font-size: 96rpx;
  line-height: 1;
  margin-bottom: 20rpx;
  display: block;
  filter: drop-shadow(0 8rpx 20rpx rgba(0,0,0,0.08));
}
.hero-name {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -0.5rpx;
  line-height: 1.2;
  display: block;
  margin-bottom: 16rpx;
}
.hero-meta {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
  flex-wrap: wrap;
}
.hero-tag {
  font-size: 22rpx;
  font-weight: 500;
  color: var(--text-secondary);
  background: rgba(0,0,0,0.04);
  padding: 8rpx 18rpx;
  border-radius: var(--radius-pill);
}
.hero-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  margin-bottom: 36rpx;
  display: block;
}
.hero-actions {
  display: flex;
  gap: 20rpx;
  justify-content: center;
}
.hero-actions .btn-glass { flex: 1; }

/* ===== 换种方式决定（玩法宫格） ===== */
.play-section-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-tertiary);
  margin: 36rpx 4rpx 20rpx;
}
.play-grid {
  display: flex;
  gap: 20rpx;
}
.play-card {
  flex: 1;
  background: var(--card-bg);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  padding: 28rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  transition: transform var(--transition-fast);
}
.play-card:active { transform: scale(0.96); }
.play-emoji { font-size: 48rpx; line-height: 1; }
.play-label { font-size: 24rpx; font-weight: 500; color: var(--text-secondary); }

/* ===== 玩法聚焦态返回头 ===== */
.play-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}
.play-back {
  display: flex;
  align-items: center;
  gap: 4rpx;
  justify-content: flex-start;
  padding-right: 16rpx;
}
.play-back-icon { font-size: 40rpx; font-weight: 600; color: var(--primary); line-height: 1; }
.play-back-text { font-size: 30rpx; color: var(--primary); }
.play-title { font-size: 34rpx; font-weight: 600; color: var(--text-primary); }

/* ===== 凑一桌行 ===== */
.combo-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 4rpx;
  border-bottom: 1rpx solid var(--separator);
}
.combo-emoji { font-size: 48rpx; }
.combo-info { flex: 1; text-align: left; }
.combo-name { display: block; font-size: 30rpx; font-weight: 600; color: var(--text-primary); }
.combo-meta { margin-top: 4rpx; justify-content: flex-start; }

/* ===== 转盘区域 ===== */
.wheel-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
  animation: popIn 0.6s var(--transition-spring) both;
}
.wheel-wrap {
  position: relative;
  width: 520rpx;
  height: 520rpx;
  margin: 0 auto;
}
.wheel-container {
  width: 520rpx;
  height: 520rpx;
  border-radius: 50%;
  position: relative;
  overflow: hidden;
  background: var(--glass-bg-strong);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border: 1rpx solid var(--glass-border);
  box-shadow: var(--shadow-glass), inset 0 0 0 1rpx rgba(255,255,255,0.5);
}
.wheel-divider {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 50%;
  height: 2rpx;
  background: rgba(0,0,0,0.08);
  transform-origin: 0 50%;
  margin-top: -1rpx;
}
.wheel-tick {
  position: absolute;
  top: 4rpx;
  left: 50%;
  width: 8rpx;
  height: 2rpx;
  background: rgba(0,0,0,0.12);
  transform-origin: 0 256rpx;
  margin-left: -4rpx;
}
.wheel-tick-major {
  width: 16rpx;
  height: 3rpx;
  background: rgba(0,0,0,0.2);
  margin-left: -8rpx;
}
.wheel-emoji-wrap {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 60rpx;
  height: 60rpx;
  margin-left: -30rpx;
  margin-top: -30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.wheel-emoji {
  font-size: 48rpx;
}
.wheel-center {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 140rpx;
  height: 140rpx;
  margin-left: -70rpx;
  margin-top: -70rpx;
  background: var(--text-inverse);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.08), inset 0 0 0 4rpx rgba(255,255,255,0.8);
  z-index: 2;
}
.wheel-center-text {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--primary);
  letter-spacing: 2rpx;
}
.wheel-pointer {
  position: absolute;
  top: -16rpx;
  left: 50%;
  margin-left: -14rpx;
  width: 0;
  height: 0;
  border-left: 14rpx solid transparent;
  border-right: 14rpx solid transparent;
  border-bottom: 32rpx solid var(--primary);
  filter: drop-shadow(0 2rpx 6rpx rgba(0,0,0,0.15));
  z-index: 10;
}
.wheel-meta {
  margin-top: 24rpx;
}
.wheel-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  text-align: center;
}
.wheel-empty-emoji {
  font-size: 80rpx;
  display: block;
  margin-bottom: 16rpx;
}
.wheel-empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
}
.wheel-empty-sub {
  font-size: 26rpx;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 8rpx;
}
.reveal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9998;
  background: rgba(248,248,250,0.85);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  animation: fadeIn 0.3s ease both;
}
.reveal-pulse {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: var(--glass-bg-strong);
  backdrop-filter: blur(40rpx);
  border: 1rpx solid var(--glass-border);
  box-shadow: var(--shadow-glass);
  display: flex;
  align-items: center;
  justify-content: center;
  animation: popIn 0.5s var(--transition-spring) both, glowPulse 1s ease-in-out infinite;
}
.reveal-text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary);
}
.pk-punishment {
  background: var(--primary-soft);
  border-radius: var(--radius-md);
  padding: 20rpx 32rpx;
  margin: 16rpx 0 24rpx;
  text-align: center;
}
.pk-punishment-text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary);
  display: block;
}
.wheel-hint {
  font-size: 24rpx;
  color: var(--text-tertiary);
  display: block;
  margin-bottom: 8rpx;
}

/* 按钮 .btn-glass* 已统一定义于全局 app.wxss（去重） */

/* ===== 筛选触发胶囊 ===== */
.filter-trigger-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  background: var(--glass-bg);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--glass-border);
  box-shadow: var(--glass-highlight), var(--shadow-soft);
  margin-top: 24rpx;
}
.filter-trigger-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.filter-trigger-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}
.filter-trigger-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--primary);
}
.filter-trigger-summary {
  font-size: 26rpx;
  color: var(--text-tertiary);
  flex: 1;
  text-align: right;
  margin-right: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.filter-trigger-chevron {
  font-size: 24rpx;
  color: var(--text-tertiary);
  transform: rotate(90deg);
}

/* ===== 筛选 Sheet ===== */
.filter-sheet-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  background: rgba(0,0,0,0.25);
  backdrop-filter: blur(8rpx);
  -webkit-backdrop-filter: blur(8rpx);
  animation: fadeIn 0.25s ease-out both;
}
.filter-sheet {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--glass-bg-strong);
  backdrop-filter: blur(80rpx);
  -webkit-backdrop-filter: blur(80rpx);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  border: 1rpx solid var(--glass-border);
  border-bottom: none;
  box-shadow: var(--glass-highlight), 0 -20rpx 60rpx rgba(31,35,45,0.12);
  padding: 24rpx 40rpx 60rpx;
  animation: sheetSlideUp 0.3s cubic-bezier(0.32, 0.72, 0, 1) both;
  overflow: hidden;
}
.filter-sheet-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 0 24rpx;
  margin-bottom: 16rpx;
  border-bottom: 1rpx solid var(--glass-stroke);
  position: relative;
  z-index: 1;
}
.filter-sheet-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}
.filter-sheet-action {
  font-size: 28rpx;
  color: var(--text-secondary);
  padding: 8rpx 0;
}
.filter-sheet-action.active {
  color: var(--primary);
}
.filter-group {
  background: var(--glass-bg);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--glass-border);
  box-shadow: var(--glass-highlight), var(--shadow-soft);
  overflow: hidden;
  position: relative;
  z-index: 1;
}
.filter-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid var(--glass-stroke);
}
.filter-row:last-child {
  border-bottom: none;
}
.filter-label {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
}
.filter-value {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: var(--text-tertiary);
}
.filter-value.active {
  color: var(--primary);
  font-weight: 500;
}
.filter-chevron {
  font-size: 22rpx;
  color: var(--text-tertiary);
}
.toggle-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
}
.toggle-ios {
  width: 100rpx;
  height: 56rpx;
  border-radius: 28rpx;
  background: var(--text-tertiary);
  position: relative;
  transition: background var(--transition-fast);
  box-shadow: inset 0 2rpx 6rpx rgba(0,0,0,0.15);
}
.toggle-ios.on {
  background: var(--primary);
}
.toggle-ios::after {
  content: '';
  position: absolute;
  width: 48rpx;
  height: 48rpx;
  background: var(--text-inverse);
  border-radius: 50%;
  top: 4rpx;
  left: 4rpx;
  transition: transform var(--transition-fast);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.15);
}
.toggle-ios.on::after {
  transform: translateX(44rpx);
}

/* ===== 模式内容区 ===== */
.mode-content {
  animation: fadeIn 0.4s var(--transition-base) both;
}

/* ===== 塔罗 ===== */
.tarot-grid {
  display: flex;
  justify-content: center;
  gap: 32rpx;
  margin: 40rpx 0;
}
.tarot-card-glass {
  width: 200rpx;
  height: 280rpx;
  background: var(--glass-bg-strong);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--glass-border);
  box-shadow: var(--glass-highlight), var(--shadow-glass);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: all var(--transition-base);
  position: relative;
  overflow: hidden;
}
.tarot-card-glass::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 50%;
  background: linear-gradient(180deg, rgba(255,255,255,0.4) 0%, transparent 100%);
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  pointer-events: none;
}
.tarot-card-glass.flipped {
  background: linear-gradient(135deg, rgba(255,122,107,0.15) 0%, rgba(255,122,107,0.05) 100%);
}
.tarot-card-glass:active {
  transform: scale(0.96);
}
.tarot-card-inner {
  position: relative;
  z-index: 2;
  text-align: center;
}
.tarot-card-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
  display: block;
}
.tarot-card-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
}
.tarot-card-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-top: 8rpx;
}
.tarot-fortune-glass {
  background: var(--glass-bg);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--glass-border);
  box-shadow: var(--glass-highlight), var(--shadow-soft);
  padding: 40rpx;
  text-align: center;
  margin-top: 32rpx;
}
.tarot-fortune-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--primary);
  display: block;
  margin-bottom: 12rpx;
}
.tarot-fortune-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

/* ===== PK ===== */
.pk-grid {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}
.pk-card {
  background: var(--glass-bg);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--glass-border);
  box-shadow: var(--glass-highlight), var(--shadow-soft);
  padding: 32rpx;
}
.pk-card.placeholder {
  opacity: 0.45;
}
.pk-card-label {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-tertiary);
  text-transform: uppercase;
  letter-spacing: 1rpx;
  margin-bottom: 20rpx;
  display: block;
}
.pk-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.pk-option {
  padding: 16rpx 32rpx;
  border-radius: var(--radius-pill);
  background: rgba(0,0,0,0.04);
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  transition: all var(--transition-fast);
}
.pk-option:active {
  transform: scale(0.96);
}
.pk-option.selected {
  background: var(--primary);
  color: var(--text-inverse);
  box-shadow: 0 4rpx 16rpx var(--primary-glow);
}
.pk-option.disabled {
  opacity: 0.35;
}
.pk-result-glass {
  background: var(--glass-bg-strong);
  backdrop-filter: blur(60rpx);
  -webkit-backdrop-filter: blur(60rpx);
  border-radius: var(--radius-xl);
  border: 1rpx solid var(--glass-border);
  box-shadow: var(--glass-highlight), var(--shadow-glass);
  padding: 48rpx;
  text-align: center;
  margin-top: 32rpx;
  animation: floatUp 0.5s var(--transition-spring) both;
}
.pk-result-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  margin-bottom: 16rpx;
}
.pk-food-card {
  background: var(--primary-soft);
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin: 0 auto 24rpx;
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.pk-food-emoji {
  font-size: 64rpx;
  line-height: 1;
}
.pk-food-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--primary);
}
.pk-result-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  display: block;
  margin-bottom: 32rpx;
}
.pk-meter {
  margin: 32rpx 0;
}
.pk-meter-track {
  height: 8rpx;
  background: rgba(0,0,0,0.06);
  border-radius: 4rpx;
  overflow: hidden;
}
.pk-meter-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary), var(--blue-accent));
  border-radius: 4rpx;
  transition: width 0.8s cubic-bezier(0.4, 0, 0.2, 1);
}
.pk-meter-labels {
  display: flex;
  justify-content: space-between;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: var(--text-tertiary);
}
.pk-actions {
  display: flex;
  justify-content: center;
  margin-top: 24rpx;
}
.pk-actions .btn-glass {
  min-width: 280rpx;
}

/* ===== 盲盒 ===== */
.blindbox-glass {
  width: 320rpx;
  height: 320rpx;
  margin: 40rpx auto;
  background: var(--glass-bg-strong);
  backdrop-filter: blur(60rpx);
  -webkit-backdrop-filter: blur(60rpx);
  border-radius: var(--radius-xl);
  border: 1rpx solid var(--glass-border);
  box-shadow: var(--glass-highlight), var(--shadow-glass), 0 0 60rpx var(--primary-soft);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  transition: all var(--transition-base);
}
.blindbox-glass::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 50%;
  background: linear-gradient(180deg, rgba(255,255,255,0.5) 0%, transparent 100%);
  pointer-events: none;
}
.blindbox-glass.shaking {
  animation: shake 0.5s ease infinite;
}
.blindbox-glass.opened {
  box-shadow: var(--glass-highlight), var(--shadow-glass), 0 0 100rpx var(--primary-glow);
}
.blindbox-icon {
  font-size: 80rpx;
  position: relative;
  z-index: 2;
  filter: drop-shadow(0 8rpx 20rpx rgba(0,0,0,0.1));
}
.blindbox-label {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-secondary);
  margin-top: 20rpx;
  position: relative;
  z-index: 2;
}
/* FIX: 盲盒稀有度徽章 + 光效 */
.blindbox-rarity {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  font-size: 22rpx;
  font-weight: 700;
  padding: 6rpx 16rpx;
  border-radius: 10rpx;
  color: #fff;
  z-index: 3;
  letter-spacing: 2rpx;
}
.blindbox-glass.rarity-R .blindbox-rarity { background: #8E8E93; }
.blindbox-glass.rarity-SR .blindbox-rarity { background: linear-gradient(135deg, #36A2EB, #4BC0C0); }
.blindbox-glass.rarity-SSR .blindbox-rarity { background: linear-gradient(135deg, #FF9F43, #FF6B6B); }
.blindbox-glass.rarity-SSR { box-shadow: var(--glass-highlight), var(--shadow-glass), 0 0 120rpx rgba(255,159,67,0.5); }
.blindbox-glow {
  position: absolute;
  top: 50%; left: 50%;
  width: 300rpx; height: 300rpx;
  transform: translate(-50%, -50%);
  background: radial-gradient(circle, rgba(255,159,67,0.35) 0%, transparent 70%);
  animation: glowPulse 1.2s ease-in-out infinite;
  pointer-events: none;
  z-index: 1;
}
/* ===== 自定义选择器弹窗 ===== */
.picker-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10000;
  background: rgba(0,0,0,0.25);
  backdrop-filter: blur(8rpx);
  -webkit-backdrop-filter: blur(8rpx);
  animation: fadeIn 0.25s ease-out both;
}
.picker-sheet {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--glass-bg-strong);
  backdrop-filter: blur(80rpx);
  -webkit-backdrop-filter: blur(80rpx);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  border: 1rpx solid var(--glass-border);
  border-bottom: none;
  box-shadow: var(--glass-highlight), 0 -20rpx 60rpx rgba(31,35,45,0.12);
  padding: 24rpx 32rpx 60rpx;
  animation: sheetSlideUp 0.3s cubic-bezier(0.32, 0.72, 0, 1) both;
  overflow: hidden;
}
.picker-sheet .sheet-solid-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--page-bg);
  opacity: 0.96;
  z-index: 0;
  pointer-events: none;
}
.picker-sheet > .sheet-handle,
.picker-sheet > .picker-title,
.picker-sheet > .picker-list,
.picker-sheet > .picker-cancel-wrap {
  position: relative;
  z-index: 1;
}
.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  text-align: center;
  display: block;
  margin-bottom: 24rpx;
}
.picker-list {
  background: var(--glass-bg);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--glass-border);
  overflow: hidden;
  margin-bottom: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 24rpx;
  justify-content: center;
  max-height: 480rpx;
  overflow-y: auto;
}
.picker-item {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx 32rpx;
  border-radius: var(--radius-pill);
  background: rgba(0,0,0,0.04);
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  transition: all 0.15s ease;
}
.picker-item:active {
  transform: scale(0.96);
  background: rgba(0,0,0,0.06);
}
.picker-item.active {
  background: var(--primary);
  color: var(--text-inverse);
  box-shadow: 0 4rpx 16rpx var(--primary-glow);
}
.picker-item-text {
  font-size: 28rpx;
  color: inherit;
}
.picker-item.active .picker-item-text {
  font-weight: 600;
}
.picker-check {
  font-size: 22rpx;
  color: inherit;
  font-weight: 700;
}
.picker-cancel-wrap {
  padding: 0 0 16rpx;
}

/* ===== Bottom Sheet 弹窗 ===== */
.sheet-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  background: rgba(0,0,0,0.25);
  backdrop-filter: blur(8rpx);
  -webkit-backdrop-filter: blur(8rpx);
  animation: fadeIn 0.25s ease-out both;
}
.sheet-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--glass-bg-strong);
  backdrop-filter: blur(80rpx);
  -webkit-backdrop-filter: blur(80rpx);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  border: 1rpx solid var(--glass-border);
  border-bottom: none;
  box-shadow: var(--glass-highlight), 0 -20rpx 60rpx rgba(31,35,45,0.12);
  padding: 24rpx 40rpx 60rpx;
  animation: sheetSlideUp 0.3s cubic-bezier(0.32, 0.72, 0, 1) both;
  overflow: hidden;
}
.sheet-solid-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--page-bg);
  opacity: 0.96;
  z-index: 0;
  pointer-events: none;
}
/* 内容仅需层级定位；入场交给 Sheet 整体滑入，避免逐元素 stagger 拖慢感知 */
.sheet-content > .sheet-handle,
.sheet-content > .sheet-emoji,
.sheet-content > .sheet-name,
.sheet-content > .sheet-meta,
.sheet-content > .sheet-desc,
.sheet-content > .sheet-actions,
.sheet-content > .combo-row,
.sheet-content > .btn-glass {
  position: relative;
  z-index: 1;
}
.sheet-handle {
  width: 72rpx;
  height: 6rpx;
  background: var(--text-tertiary);
  border-radius: 3rpx;
  margin: 0 auto 32rpx;
  opacity: 0.4;
}
.sheet-emoji {
  font-size: 80rpx;
  text-align: center;
  display: block;
  margin-bottom: 16rpx;
}
.sheet-name {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  text-align: center;
  display: block;
  margin-bottom: 16rpx;
}
.sheet-meta {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
  flex-wrap: wrap;
}
.sheet-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  text-align: center;
  line-height: 1.5;
  margin-bottom: 40rpx;
  display: block;
}
.sheet-actions {
  display: flex;
  gap: 16rpx;
  justify-content: center;
}
.sheet-actions .btn-glass {
  flex: 1;
}

/* ===== 启动页 ===== */
.intro-glass {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: var(--page-bg);
  transition: opacity 0.8s ease;
}
.intro-glass.fading {
  opacity: 0;
  pointer-events: none;
}
.intro-orb {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: radial-gradient(circle, var(--primary-soft) 0%, transparent 70%);
  filter: blur(20rpx);
  animation: glowPulse 2s ease-in-out infinite;
  display: flex;
  align-items: center;
  justify-content: center;
}
.intro-orb-inner {
  font-size: 80rpx;
  filter: drop-shadow(0 4rpx 12rpx rgba(0,0,0,0.1));
}
.intro-title-glass {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-top: 32rpx;
  letter-spacing: -0.5rpx;
}
.intro-sub-glass {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: 12rpx;
}

/* ===== 响应式 ===== */
@media (min-width: 375px) {
  .pk-grid {
    flex-direction: row;
  }
}

/* FIX: 平板横屏优化 */
@media (min-width: 768px) {
  .wheel-container {
    width: 600rpx;
    height: 600rpx;
  }
  .wheel-wrap {
    padding: 60rpx 0;
  }
  .filter-row {
    padding: 28rpx 32rpx;
  }
  .mode-content {
    padding: 48rpx;
  }
  .tarot-card-glass {
    width: 200rpx;
    height: 280rpx;
  }
  .blindbox-glass {
    width: 400rpx;
    height: 400rpx;
  }
  .pk-grid {
    gap: 32rpx;
  }
  .pk-option {
    padding: 28rpx;
    font-size: 30rpx;
  }
}
